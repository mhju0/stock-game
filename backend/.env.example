# REQUIRED — app will refuse to start without this.
# Generate a strong random secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Optional: override the frontend origin for CORS
# FRONTEND_URL=https://your-production-frontend.com

# Optional: Supabase Postgres connection string. Unset falls back to local SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local-only developer fund controls. Keep false/unset in production.
ENABLE_DEV_TOOLS=false
